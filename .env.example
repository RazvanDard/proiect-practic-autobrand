# Shared secret protecting the scraper REST service (must match in scraper/.env and Convex env).
SCRAPER_SHARED_SECRET=change-me-to-a-long-random-string

# Public URL of the Python scraper service, reachable from Convex actions.
SCRAPER_BASE_URL=http://host.docker.internal:8000

# web-scraping.dev demo credentials (any value works on that site).
SCRAPING_DEV_USERNAME=user123
SCRAPING_DEV_PASSWORD=password
